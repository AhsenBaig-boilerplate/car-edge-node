{
    "name": "car-edge-node-dev",
    "dockerFile": "Dockerfile",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/common-utils:2": {}
    },
    "postCreateCommand": "sudo apt-get update && sudo apt-get install -y flatpak wireguard-tools",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.makefile-tools",
                "ms-azuretools.vscode-docker",
                "github.copilot",
                "github.copilot-chat",
                "timonwong.shellcheck"
            ]
        }
    }
}